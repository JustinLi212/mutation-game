; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Numpad Nemesis"
run/main_scene="res://scenes/opening/opening.tscn"
config/features=PackedStringArray("4.7")
config/icon="uid://h8t34ms5hkmv"

[audio]

buses/default_bus_layout="uid://dlo5inop6ahho"
driver/output_latency.web=15

[autoload]

EventBus="*uid://cf7pey8wj1n8s"
AppConfig="*uid://cjke6crjg14a0"
SceneLoader="*uid://cbwmrnp0af35y"
ProjectMusicController="*uid://r5t485lr3p7t"
ProjectUISoundController="*uid://cc37235kj4384"
Dialogic="*uid://ds2q0uclmolvu"
GameManager="*uid://dydiws25tny73"
WinLoseManager="*uid://bmlwpkrav3q56"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={
"tutorial": "res://tutorial.dtl",
"tutorial1": "res://resources/dialog/tutorial1.dtl",
"tutorial2": "res://tutorial2.dtl"
}
layout/style_directory={
"": "res://addons/dialogic/Modules/DefaultLayoutParts/Layer_VN_Textbox/New_File.tres",
"New_File": "res://addons/dialogic/Modules/DefaultLayoutParts/Layer_VN_Textbox/New_File.tres"
}
text/letter_speed=0.01
text/initial_text_reveal_skippable=false
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/input_action="advance_dialogue"
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "SFX",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
text/autoadvance_enabled=false
history/simple_history_enabled=false
layout/style_list=["res://addons/dialogic/Modules/DefaultLayoutParts/Layer_VN_Textbox/New_File.tres"]
layout/default_style="res://addons/dialogic/Modules/DefaultLayoutParts/Layer_VN_Textbox/New_File.tres"
glossary/default_case_sensitive=true
variables={}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/maaacks_game_template/plugin.cfg")

[global_group]

grids=""

[gui]

theme/custom="uid://2qh3aix7i37a"
theme/custom_font="uid://chduaqen2k006"
common/drop_mouse_on_gui_input_disabled=true

